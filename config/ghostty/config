# Font configuration
font-family = 0xProto Nerd Font
font-size = 14
font-feature = -liga
font-feature = -calt

# Window appearance
window-decoration = false
macos-titlebar-style = hidden
window-padding-x = 15
window-padding-y = 15

# Theme colors (Tokyo Night)
background = #16161e
foreground = #c0caf5

# Transparency and blur
background-opacity = 0.90
background-blur-radius = 25

# Cursor configuration
cursor-style = block
cursor-style-blink = false
cursor-color = #c0caf5

# Shell integration
shell-integration = detect
shell-integration-features = no-cursor,no-sudo,title

# Performance settings
window-vsync = true
mouse-hide-while-typing = true

# Base colors (Tokyo Night)
palette = 0=#16161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5=#bb9af7
palette = 6=#7dcfff
palette = 7=#c0caf5
palette = 8=#414868
palette = 9=#ff7a93
palette = 10=#b9f27c
palette = 11=#ff9e64
palette = 12=#7da6ff
palette = 13=#bb9af7
palette = 14=#7dcfff
palette = 15=#d5daf5

# Selection behavior
selection-foreground = #16161e
selection-background = #7aa2f7
copy-on-select = false

# Window behavior
quit-after-last-window-closed = true
window-inherit-working-directory = true
window-padding-color = background
